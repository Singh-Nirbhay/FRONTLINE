# Database connection string for PostgreSQL (Docker Compose service 'db')
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/frontline_triage?schema=public"

# Redis connection URL (Docker Compose service 'redis')
REDIS_URL="redis://localhost:6379"

# ── AI Provider (Groq) ──────────────────────────────
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
GROQ_MODEL=llama-3.3-70b-versatile

# Confidence threshold below which a triage result needs human review (default is 0.72)
CONFIDENCE_THRESHOLD=0.72

# Maximum number of retries for external LLM API calls and queuing operations
MAX_RETRIES=3

# Concurrency limit for processing incoming messages in the triage pipeline
CONCURRENCY=5
